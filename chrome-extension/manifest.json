{
  "manifest_version": 3,
  "name": "STYLA Measure Companion",
  "version": "1.0",
  "description": "Your digital twin sizing assistant. Works on any clothing store.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ]
}
