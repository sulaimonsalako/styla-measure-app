{
  "manifest_version": 3,
  "name": "STYLA Measure Companion",
  "version": "1.0",
  "description": "Your digital twin sizing assistant. Works on any clothing store.",
  "action": {
    "default_popup": "popup.html"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "https://*.vercel.app/*",
        "https://styla.ca/*",
        "https://*.styla.ca/*"
      ],
      "js": ["content-sync.js"],
      "run_at": "document_end"
    }
  ]
}
