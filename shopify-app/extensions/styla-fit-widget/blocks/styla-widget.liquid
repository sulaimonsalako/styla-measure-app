{% comment %}
  STYLA Fit Advisor storefront widget block.
{% endcomment %}

<div class="styla-widget-container" 
     id="styla-widget-{{ block.id }}" 
     data-product-id="{{ product.id }}"
     data-product-title="{{ product.title | escape }}"
     data-product-handle="{{ product.handle }}"
     data-customer-id="{{ customer.id }}"
     {{ block.shopify_attributes }}>
     
  <!-- PDP Button -->
  <button type="button" class="styla-fit-btn" id="styla-trigger-btn-{{ block.id }}" style="
    --btn-bg: {{ block.settings.btn_bg }};
    --btn-color: {{ block.settings.btn_color }};
  ">
    <svg class="styla-btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
      <circle cx="12" cy="7" r="4" />
    </svg>
    <span class="styla-btn-text">{{ block.settings.btn_label }}</span>
  </button>
</div>

<!-- Modal Structure (Text-based Layout) -->
<div class="styla-modal-overlay styla-hidden" id="styla-modal-{{ block.id }}">
  <div class="styla-modal-container">
    <!-- Close Button -->
    <button class="styla-modal-close" id="styla-close-{{ block.id }}">&times;</button>
    
    <div class="styla-modal-body">
      <!-- 1. Left Column: Product Featured Image -->
      <div class="styla-modal-left" style="background-image: url('{{ product.featured_image | image_url: width: 600 }}');">
        <div class="styla-product-overlay">
          <span class="styla-product-badge">GARMENT PREVIEW</span>
        </div>
      </div>
      
      <!-- 2. Right Column: Sizing & Chat Panel -->
      <div class="styla-modal-right">
        <!-- Tab Bar -->
        <div class="styla-tabs-bar">
          <div class="styla-tabs">
            <button class="styla-tab-btn active" data-tab="styla-tab-fit-{{ block.id }}">Fit Advisor</button>
            <button class="styla-tab-btn" data-tab="styla-tab-chat-{{ block.id }}">Ask AI Tailor</button>
          </div>
        </div>
        
        <!-- Tab Panel 1: Sizing Details (Clean Text-based Layout) -->
        <div class="styla-tab-content active" id="styla-tab-fit-{{ block.id }}">
          <div class="styla-text-rec-container">
            <!-- Top Section: Best Option Info & Edit Button -->
            <div class="styla-best-option-row">
              <div class="styla-best-option-box">
                <span class="styla-option-label">BEST OPTION</span>
                <div class="styla-option-val">
                  <span id="styla-best-size-val-{{ block.id }}">M</span>
                  <svg class="styla-check-icon" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                  </svg>
                </div>
              </div>
              <button type="button" class="styla-edit-specs-btn" id="styla-edit-specs-{{ block.id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                  <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4Z"></path>
                </svg>
                Edit Specs
              </button>
            </div>
            
            <!-- Sizing Details Content Area (Toggles with Input Form) -->
            <div class="styla-fit-details-body" id="styla-details-body-{{ block.id }}">
              <!-- Middle Section: Sizing Details List -->
              <div class="styla-fit-analysis-panel">
                <span class="styla-panel-title">Fit details relative to your body:</span>
                <ul class="styla-text-analysis-list" id="styla-text-list-{{ block.id }}">
                  <!-- Will be dynamically populated via JS -->
                </ul>
              </div>
              
              <!-- Designer Intent Card -->
              <div class="styla-intent-card">
                <p id="styla-intent-text-{{ block.id }}">Designed as a "Relaxed Fit" tee. Choosing Size S is NOT recommended because the Chest would fit tight (-0.5" ease).</p>
              </div>
              
              <!-- Bottom Section: Also Try Sizes slider -->
              <div class="styla-size-picker-section">
                <span class="styla-picker-title">Also try the sizes:</span>
                <div class="styla-size-slider-row">
                  <button type="button" class="styla-arrow-btn prev" id="styla-prev-size-{{ block.id }}">&lt;</button>
                  <div class="styla-size-options-list">
                    <button type="button" class="styla-size-opt-btn" data-size="S">S</button>
                    <button type="button" class="styla-size-opt-btn active" data-size="M">M</button>
                    <button type="button" class="styla-size-opt-btn" data-size="L">L</button>
                  </div>
                  <button type="button" class="styla-arrow-btn next" id="styla-next-size-{{ block.id }}">&gt;</button>
                </div>
              </div>
            </div>

            <!-- Manual Specs Input Form (Hidden by default) -->
            <div class="styla-specs-form styla-hidden" id="styla-form-{{ block.id }}">
              <span class="styla-form-title">Enter your body measurements:</span>
              <div class="styla-form-grid">
                <div class="styla-form-group">
                  <label for="styla-in-shoulders-{{ block.id }}">Shoulder Width (in)</label>
                  <input type="number" id="styla-in-shoulders-{{ block.id }}" value="17.0" step="0.1" min="10" max="30">
                </div>
                <div class="styla-form-group">
                  <label for="styla-in-chest-{{ block.id }}">Chest Circumference (in)</label>
                  <input type="number" id="styla-in-chest-{{ block.id }}" value="36.0" step="0.5" min="20" max="60">
                </div>
                <div class="styla-form-group">
                  <label for="styla-in-waist-{{ block.id }}">Waist Circumference (in)</label>
                  <input type="number" id="styla-in-waist-{{ block.id }}" value="31.0" step="0.5" min="20" max="60">
                </div>
              </div>
              <div class="styla-form-actions">
                <button type="button" class="styla-form-btn cancel" id="styla-cancel-specs-{{ block.id }}">Cancel</button>
                <button type="button" class="styla-form-btn save" id="styla-save-specs-{{ block.id }}">Calculate Fit</button>
              </div>
            </div>
            
          </div>
        </div>
        
        <!-- Tab Panel 2: AI Tailor Chat -->
        <div class="styla-tab-content" id="styla-tab-chat-{{ block.id }}">
          <div class="styla-chat-container">
            <div class="styla-chat-history" id="styla-chat-history-{{ block.id }}">
              <div class="chat-msg system">
                <p>Hello! I am your STYLA AI Tailor. Ask me anything about how this item fits your body, its fabric composition, or styling suggestions.</p>
              </div>
            </div>
            <div class="styla-chat-input-bar">
              <input type="text" class="styla-chat-input" id="styla-chat-input-{{ block.id }}" placeholder="Ask about sizing, fabric, or fit...">
              <button type="button" class="styla-chat-send" id="styla-chat-send-{{ block.id }}">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="22" y1="2" x2="11" y2="13"></line>
                  <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
                </svg>
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

{{ 'styla-widget.css' | asset_url | stylesheet_tag }}
<script src="{{ 'styla-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Styla Fit Advisor",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "btn_label",
      "label": "Button Label",
      "default": "Auto-Size with STYLA"
    },
    {
      "type": "color",
      "id": "btn_bg",
      "label": "Button Background Color",
      "default": "#ff2a75"
    },
    {
      "type": "color",
      "id": "btn_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ]
}
{% endschema %}
